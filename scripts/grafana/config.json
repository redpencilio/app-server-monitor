{
  "version": "0.2",
  "scripts": [
    {
      "documentation": {
        "command": "export-dashboard",
        "description": "Export one/all Grafana dashboards to ./data/dashboards",
        "arguments": ["user", "password", "dashboard_slug?"]
      },
      "environment": {
        "image": "alpine:3.21",
        "interactive": false,
        "join_networks": true,
        "script": "export-dashboard.sh"
      },
      "mounts": {
        "app": "/project/"
      }
    },
    {
      "documentation": {
        "command": "import-dashboard",
        "description": "Import one/all Grafana dashboards from ./data/dashboards",
        "arguments": ["user", "password", "dashboard_slug?"]
      },
      "environment": {
        "image": "alpine:3.21",
        "interactive": false,
        "join_networks": true,
        "script": "import-dashboard.sh"
      },
      "mounts": {
        "app": "/project/"
      }
    }
  ]
}
